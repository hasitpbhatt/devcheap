{
  "type": "module",
  "name": "devcheap",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/build.js",
    "lint:html": "html-validate index.html",
    "lint:css": "stylelint css/*.css",
    "validate:jsonl": "node -e \"const fs=require('fs');const lines=fs.readFileSync('data/deals.jsonl','utf-8').split('\\n').filter(Boolean);lines.forEach((l,i)=>{try{JSON.parse(l)}catch(e){console.error('Line '+(i+1)+': '+e.message);process.exit(1)}});console.log('✓ '+lines.length+' deals validated')\"",
    "validate:json": "jq empty data/deals.json",
    "fetch:deals": "node scripts/fetch-deals.js",
    "check:links": "npx linkinator . --recurse --skip '^(https?://)'",
    "ci": "npm run build && npm run validate:jsonl && npm test && npm run lint:html && npm run lint:css",
    "prepare": "husky"
  },
  "devDependencies": {
    "html-validate": "^9.5.0",
    "husky": "^9.0.0",
    "jsdom": "^26.0.0",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^37.0.0",
    "vitest": "^3.1.1"
  }
}
