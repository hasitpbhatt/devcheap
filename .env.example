# Newsletter settings
# Set these as Cloudflare Pages secrets (Settings > Environment variables > Secrets)
# They are read by functions/api/subscribe.js at runtime — NOT by the frontend
# Get these from your Beehiiv dashboard (Settings > API Keys)
#
#   npx wrangler pages secret put BEEHIIV_PUBLICATION_ID
#   npx wrangler pages secret put BEEHIIV_API_KEY
#
# Or set via Cloudflare Dashboard > devcheap > Settings > Environment variables
BEEHIIV_PUBLICATION_ID=your_publication_id_here
BEEHIIV_API_KEY=your_api_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# DevCheap settings
NEWSLETTER_SOURCE=devcheap.click